APP_NAME="BizHub.by"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Minsk

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=bizhub
DB_USERNAME=bizhub
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret

# ─── Sessions, Cache, Queue ───────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=bizhub_

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@bizhub.by"
MAIL_FROM_NAME="${APP_NAME}"

# ─── MinIO / S3-compatible Storage ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=bizhub
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── Meilisearch (Scout) ──────────────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey
MEILISEARCH_ENV=development

# ─── Reverb (WebSockets) ──────────────────────────────────────────────────────
REVERB_APP_ID=bizhub-app
REVERB_APP_KEY=bizhub-app-key
REVERB_APP_SECRET=bizhub-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Admin User ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@bizhub.by
ADMIN_PASSWORD=Admin@BizHub2024!
MODERATOR_PASSWORD=Mod@BizHub2024!

# ─── Media Library ────────────────────────────────────────────────────────────
MEDIA_DISK=s3

# ─── BePaid / Payment Gateway ─────────────────────────────────────────────────
BEPAID_SHOP_ID=
BEPAID_SECRET_KEY=
BEPAID_TEST_MODE=true

# ─── Vite ────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
